<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">
    <Grid RowDefinitions="Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <SearchBar x:Name="SearchBarProdutos"
                       Placeholder="Buscar por descrição..."
                       TextChanged="OnSearchTextChanged" />
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="0"
                        x:Name="BtnNovo"
                        Text="+ Novo produto"
                        Clicked="OnNovoClicked" />
                <Button Grid.Column="1"
                        Text="📊 Relatório"
                        BackgroundColor="{StaticResource Primary}"
                        Clicked="OnRelatorioClicked" />
                <Button Grid.Column="2"
                        Text="🌤 Tempo"
                        BackgroundColor="#0078D4"
                        Clicked="OnTempoClicked" />
            </Grid>
        </VerticalStackLayout>
        <CollectionView x:Name="ListaProdutos"
                        Grid.Row="1"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Nenhum produto. Toque em 'Novo produto' para adicionar."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray500}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12" Margin="0,4" Stroke="{StaticResource Gray200}" StrokeThickness="1" StrokeShape="Rectangle">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Descricao}"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Resumo}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding DataFormatada, StringFormat='🗓 {0}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                   Text="{Binding PrecoFormatado}"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   Margin="0,0,16,0" />
                            <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                                    Text="✏️"
                                    BackgroundColor="Transparent"
                                    FontSize="18"
                                    Padding="4,0"
                                    VerticalOptions="Center"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnEditarClicked" />
                            <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                                    Text="🗑"
                                    BackgroundColor="Transparent"
                                    FontSize="18"
                                    Padding="4,0"
                                    VerticalOptions="Center"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnExcluirClicked" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
